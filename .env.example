NODE_ENV=development
PORT=3000
AI_SERVICE_URL=http://ai-service:8000
SHOT_PLANNER_PROVIDER=python-service
VIDEO_GENERATION_PROVIDER=mock
REDIS_URL=redis://redis:6379
DATABASE_URL=postgres://postgres:postgres@postgres:5432/ai_video_generator
ASSET_ROOT=/app/storage
BACKEND_BASE_URL=http://localhost:3000
FFMPEG_PATH=/usr/bin/ffmpeg
ASSET_CLEANUP_ENABLED=false
KLING_API_BASE_URL=https://api.klingai.com
KLING_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_MODEL=kling-video-3.0
KLING_DURATION_SECONDS=5
KLING_ASPECT_RATIO=16:9
KLING_SUPPORTED_DURATIONS=5,10
KLING_SUPPORTED_ASPECT_RATIOS=16:9,9:16,1:1
KLING_SUPPORTED_MODELS=kling-v2.6-std,kling-v2.6-pro,kling-v2.5-turbo,kling-video-o1,kling-video-3.0,kling-video-3.0-omni,kling-3.0-omni,kling-video-o3
KLING_MODE=
KLING_NEGATIVE_PROMPT=
KLING_POLL_INTERVAL_MS=5000
KLING_TIMEOUT_MS=900000
BASE_STORAGE_PATH=/Volumes/Ultima HDD /mac/projects/video_generator_videos
